# Copy this file to `.env` and fill in the values.
# Never commit `.env` to version control.

# --- Ollama (local LLM + embedding server) ---
# Default when Ollama is running on the same machine
OLLAMA_BASE_URL=http://localhost:11434

# Model used to generate answers
OLLAMA_LLM_MODEL=llama3

# Model used to create embeddings
OLLAMA_EMBED_MODEL=mxbai-embed-large

# --- Qdrant (local vector store) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Name of the Qdrant collection that stores chunk vectors
QDRANT_COLLECTION=rag_chunks

# --- FastAPI backend ---
# Port the API server listens on
API_PORT=8000

# --- File storage ---
# Folder where raw uploaded PDFs are saved
RAW_DATA_DIR=data/raw
